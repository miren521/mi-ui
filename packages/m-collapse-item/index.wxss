.m-collapse-item{width:100%;background-color:#ffffff}.m-collapse-item.is-disabled{opacity:0.6}.m-collapse-item.is-border{border-bottom:1rpx solid #ebebeb}.m-collapse-item__header{display:flex;align-items:center;justify-content:space-between;padding:32rpx;font-size:32rpx;color:#333333;cursor:pointer;transition:all 0.3s ease}.m-collapse-item__header:active{background-color:#f5f5f5}.m-collapse-item__header.is-expanded{border-bottom:1rpx solid #ebebeb}.m-collapse-item__title{flex:1;font-weight:500}.m-collapse-item__arrow{width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;transition:transform 0.3s ease}.m-collapse-item__arrow.is-retract{transform:rotate(-180deg)}.m-collapse-item__wrapper{overflow:hidden;transition:height 0.3s ease-in-out}.m-collapse-item__body{padding:32rpx;font-size:28rpx;color:#666666;line-height:40rpx}
