.m-collapse{width:100%}.m-collapse.is-viewmore .m-collapse__content{overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-box-orient:vertical}.m-collapse.is-viewmore .m-collapse__content.is-retract{transition:all 0.3s ease}.m-collapse.is-viewmore .m-collapse__more{display:flex;align-items:center;justify-content:center;margin-top:12rpx;color:#3388ff;font-size:28rpx;cursor:pointer}.m-collapse.is-viewmore .m-collapse__more-txt{margin-right:6rpx}.m-collapse.is-viewmore .m-collapse__more-arrow{transition:transform 0.3s ease}.m-collapse.is-viewmore .m-collapse__more-arrow.is-retract{transform:rotate(-180deg)}
