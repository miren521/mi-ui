.m-cell-group{background-color:#fff}.m-cell-group.is-border .m-cell-group__title{position:relative}.m-cell-group.is-border .m-cell-group__title::after{content:'';position:absolute;left:0;bottom:0;right:0;height:1rpx;background-color:#ebedf0}.m-cell-group__title{position:relative;display:flex;justify-content:space-between;padding:24rpx;background:#fff;font-size:24rpx;color:#2e2e2e;font-weight:500;line-height:1.43;font-size:16px;border-bottom:1px solid #f0f0f0}.m-cell-group__left{font-weight:600}.m-cell-group__right{color:#999;font-size:24rpx}.m-cell-group__body{background:#fff}.m-cell-group--insert{border-radius:16rpx;overflow:hidden;margin:20rpx}
