.m-popup-wrapper{position:fixed;top:0;left:0;right:0;bottom:0;z-index:var(--m-popup-z-index, 10)}.m-popup__modal{position:absolute;top:0;left:0;right:0;bottom:0;background-color:rgba(0,0,0,0.5);transition:opacity var(--m-popup-duration, 300ms) ease}.m-popup{position:fixed;max-height:100%;overflow-y:auto;background-color:#fff;transition:transform var(--m-popup-duration, 300ms) ease,opacity var(--m-popup-duration, 300ms) ease}.m-popup__close{position:absolute;top:10px;right:10px;width:24px;height:24px;display:flex;align-items:center;justify-content:center;color:#999;cursor:pointer;z-index:1;transform:rotate(45deg)}.m-popup__header{padding:16px;border-bottom:1px solid #eee;font-size:16px;font-weight:500}.m-popup__content{padding:16px}.m-popup__footer{padding:16px;border-top:1px solid #eee}.m-popup--center{left:50%;top:50%;transform:translate3d(-50%, -50%, 0);border-radius:8px;width:80%;max-width:320px}.m-popup--top{left:0;top:0;right:0;border-radius:0 0 8px 8px;width:100%}.m-popup--right{top:0;right:0;bottom:0;border-radius:8px 0 0 8px;width:80%;max-width:320px}.m-popup--bottom{right:0;bottom:0;left:0;border-radius:8px 8px 0 0;width:100%}.m-popup--left{top:0;left:0;bottom:0;border-radius:0 8px 8px 0;width:80%;max-width:320px}.m-zoom-fade{opacity:0;transform:translate3d(-50%, -50%, 0) scale(0.8)}.m-zoom-fade--enter-active{opacity:1;transform:translate3d(-50%, -50%, 0) scale(1);transition:opacity var(--m-popup-duration, 300ms) ease,transform var(--m-popup-duration, 300ms) ease}.m-zoom-fade--leave-active{opacity:0;transform:translate3d(-50%, -50%, 0) scale(0.8);transition:opacity var(--m-popup-duration, 300ms) ease,transform var(--m-popup-duration, 300ms) ease}.m-slide-up{transform:translate3d(0, 100%, 0)}.m-slide-up--enter-active{transform:translate3d(0, 0, 0);transition:transform var(--m-popup-duration, 300ms) ease}.m-slide-up--leave-active{transform:translate3d(0, 100%, 0);transition:transform var(--m-popup-duration, 300ms) ease}.m-slide-down{transform:translate3d(0, -100%, 0)}.m-slide-down--enter-active{transform:translate3d(0, 0, 0);transition:transform var(--m-popup-duration, 300ms) ease}.m-slide-down--leave-active{transform:translate3d(0, -100%, 0);transition:transform var(--m-popup-duration, 300ms) ease}.m-slide-left{transform:translate3d(-100%, 0, 0)}.m-slide-left--enter-active{transform:translate3d(0, 0, 0);transition:transform var(--m-popup-duration, 300ms) ease}.m-slide-left--leave-active{transform:translate3d(-100%, 0, 0);transition:transform var(--m-popup-duration, 300ms) ease}.m-slide-right{transform:translate3d(100%, 0, 0)}.m-slide-right--enter-active{transform:translate3d(0, 0, 0);transition:transform var(--m-popup-duration, 300ms) ease}.m-slide-right--leave-active{transform:translate3d(100%, 0, 0);transition:transform var(--m-popup-duration, 300ms) ease}
