.demo-block{background-color:white;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.08);margin-bottom:24px;overflow:hidden}.demo-block__header{padding:16px 24px;border-bottom:1px solid #f0f0f0}.demo-block__title{font-size:18px;font-weight:600;margin:0 0 8px;color:#333}.demo-block__desc{font-size:14px;color:#666;margin:0;line-height:1.5}.demo-block__content{padding:24px}@media (max-width: 768px){.demo-block__header{padding:12px 16px}.demo-block__title{font-size:16px}.demo-block__content{padding:16px}}
